<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Shimmer3 GSR+ Integration"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- Status Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initializing Shimmer components..."
            android:textSize="14sp"
            android:textColor="#424242"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/connectionQualityText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quality: Unknown"
            android:textSize="12sp"
            android:textColor="#757575" />

    </LinearLayout>

    <!-- GSR Data Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F5E8"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/gsrValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GSR: -- µS"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2E7D32" />

            <TextView
                android:id="@+id/qualityScoreText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quality: --%"
                android:textSize="12sp"
                android:textColor="#558B2F" />

        </LinearLayout>

        <TextView
            android:id="@+id/sampleCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Samples: 0"
            android:textSize="14sp"
            android:textColor="#388E3C"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/scanButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scan Devices"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#2196F3" />

        <Button
            android:id="@+id/connectButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connect"
            android:textSize="12sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#4CAF50"
            android:enabled="false" />

        <Button
            android:id="@+id/startRecordingButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Rec"
            android:textSize="12sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#FF9800"
            android:enabled="false" />

        <Button
            android:id="@+id/stopRecordingButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stop Rec"
            android:textSize="12sp"
            android:layout_marginStart="4dp"
            android:backgroundTint="#F44336"
            android:enabled="false" />

    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Device List Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Discovered Shimmer Devices"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#424242"
        android:paddingBottom="8dp" />

    <!-- Device List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/deviceRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FAFAFA"
        android:padding="4dp" />

</LinearLayout>